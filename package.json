  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1",
    "globals": "^17.1.0",
    "jsdom": "^29.0.2",
    "prettier": "^3.6.2",
    "selenium": "^2.20.0",
    "typescript-eslint": "^8.54.0"
  },
  "dependencies": {
    "@ionic-native/in-app-browser": "^5.36.0",
