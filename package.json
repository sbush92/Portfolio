{
  "name": "portfolio",
  "version": "1.0.0",
  "private": true,
  "description": "Portfolio Website",
  "main": "index.js",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "start": "npm run dev",
    "dev": "npm run dev --workspace frontend",
    "build": "npm run build --workspace frontend",
    "preview": "npm run preview --workspace frontend",
    "test": "node --test e2e-spec.js",
    "test:pw": "node ./node_modules/playwright/cli.js test",
    "playwright": "node ./node_modules/playwright/cli.js test",
    "ci": "npm run build && npm test && npm test:pw",
    "lint": "npm run lint --workspace frontend",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "e2e": "cypress open"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sbush92/Portfolio.git"
  },
  "author": "sjbush92@gmail.com",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/sbush92/Portfolio/issues"
  },
  "homepage": "https://github.com/sbush92/Portfolio#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "chance": "^1.1.13",
    "cypress": "^15.14.2",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "selenium": "^2.20.0",
    "typescript-eslint": "^8.59.1"
  },
  "dependencies": {
    "@ionic-native/in-app-browser": "^5.36.0",
    "cordova-plugin-inappbrowser": "^6.0.0",
    "pg": "^8.20.0"
  }
}
